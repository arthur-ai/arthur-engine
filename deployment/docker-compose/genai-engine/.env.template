# GPT service type ("Azure" or "OpenAI")
GENAI_ENGINE_OPENAI_PROVIDER=OpenAI

# GPT access
# Format: <model_name>::<base_url>::<api_key>
# If using OpenAI provider, leave the base_url part of the template empty unless
# you are using a proxy or service emulator (eg: OpenAI API compatible model)
GENAI_ENGINE_OPENAI_GPT_NAMES_ENDPOINTS_KEYS=model_name::::my_api_key

# reCAPTCHA Enterprise (optional) — gates the public tenant signup endpoint.
# When all three are set, the backend verifies the client-side token via the
# reCAPTCHA Enterprise Assessments API. Leave blank to disable (verification is
# skipped). RECAPTCHA_ENTERPRISE_SITE_KEY must also be exposed to the UI build.
RECAPTCHA_ENTERPRISE_PROJECT_ID=
RECAPTCHA_ENTERPRISE_SITE_KEY=
RECAPTCHA_ENTERPRISE_API_KEY=
# Optional tuning (defaults: 0.5 / onboarding_signup)
RECAPTCHA_ENTERPRISE_SCORE_THRESHOLD=0.5
RECAPTCHA_ENTERPRISE_EXPECTED_ACTION=onboarding_signup
