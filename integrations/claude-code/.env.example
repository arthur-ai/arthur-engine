# Fill in the following ENV vars

GENAI_ENGINE_API_KEY="ARTHUR_ENGINE_API_KEY"
GENAI_ENGINE_TASK_ID="ARTHUR_TASK_ID"
GENAI_ENGINE_TRACE_ENDPOINT=http://localhost:3030/api/v1/traces     # This is the local endpoint for the GenAI Engine. Change to the remote endpoint if you are using the remote GenAI Engine.