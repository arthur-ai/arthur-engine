# Copy this file to .env.local and fill in your recording token
METICULOUS_RECORDING_TOKEN=your_recording_token_here
AMPLITUDE_API_KEY=your_amplitude_key_here
# reCAPTCHA Enterprise score-based site key for the onboarding form (optional).
# Leave blank to disable reCAPTCHA on the client. Must match the site key the
# backend assesses against.
RECAPTCHA_ENTERPRISE_SITE_KEY=your_recaptcha_enterprise_site_key_here
