{
  "name": "ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "dev": "vite --mode dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc -b --noEmit",
    "check": "yarn type-check && yarn lint && yarn format:check",
    "preview": "vite preview",
    "generate-api": "yarn dlx swagger-typescript-api@13.0.16 -p ../staging.openapi.json -o src/lib/api-client --name api-client.ts --axios --clean-output --extract-request-params --extract-request-body --extract-response-body --extract-response-error --extract-enums --union-enums --add-readonly --sort-routes --sort-types",
    "generate-api:clean": "rm -rf src/lib/api-client && yarn generate-api"
  },
  "dependencies": {
    "@amplitude/analytics-browser": "2.36.2",
    "@arizeai/openinference-semantic-conventions": "2.1.7",
    "@arthur/shared-components": "3.15.2",
    "@base-ui/react": "1.2.0",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@monaco-editor/react": "4.7.0",
    "@mui/icons-material": "7.3.9",
    "@mui/material": "7.3.9",
    "@mui/x-charts": "8.27.4",
    "@mui/x-date-pickers": "8.27.2",
    "@tanstack/react-form": "1.28.4",
    "@tanstack/react-pacer": "0.19.4",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-query-devtools": "5.91.3",
    "@tanstack/react-table": "8.21.3",
    "axios": "1.13.6",
    "dayjs": "1.11.19",
    "framer-motion": "12.35.2",
    "material-react-table": "3.2.1",
    "monaco-editor": "0.55.1",
    "notistack": "3.0.2",
    "nuqs": "2.8.9",
    "ohash": "2.0.11",
    "papaparse": "5.5.3",
    "prism-react-renderer": "2.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "6.1.1",
    "react-markdown": "10.1.0",
    "react-router-dom": "7.13.1",
    "react-syntax-highlighter": "15.6.6",
    "react-use-measure": "2.1.7",
    "remark-gfm": "4.0.1",
    "swagger-typescript-api": "13.3.1",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.1",
    "usehooks-ts": "3.1.1",
    "uuid": "13.0.0",
    "weaviate-client": "3.12.0",
    "zod": "4.3.6",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/eslint-plugin-query": "5.91.4",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/node": "24.12.2",
    "@types/papaparse": "5.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "16.5.0",
    "prettier": "3.7.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite": "7.3.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.54.0"
  }
}
