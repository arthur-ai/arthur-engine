    {
      "_comment": "python3.11: the unused Python 3.11 runtime inherited from the distroless base (the app runs Python 3.12/3.13 from /usr/local) was deleted from the image — files AND dpkg metadata — so the component is no longer present. Affects libpython3.11-minimal, libpython3.11-stdlib, python3.11-minimal.",
      "vulnerability": { "name": "CVE-2025-8194" },
      "products": [
        { "@id": "pkg:oci/genai-engine-cpu", "subcomponents": [ { "@id": "pkg:deb/debian/python3.11-minimal@3.11.2-6+deb12u6?distro=debian-12" }, { "@id": "pkg:deb/debian/libpython3.11-minimal@3.11.2-6+deb12u6?distro=debian-12" }, { "@id": "pkg:deb/debian/libpython3.11-stdlib@3.11.2-6+deb12u6?distro=debian-12" } ] },
        { "@id": "pkg:oci/genai-engine-gpu", "subcomponents": [ { "@id": "pkg:deb/debian/python3.11-minimal@3.11.2-6+deb12u6?distro=debian-12" }, { "@id": "pkg:deb/debian/libpython3.11-minimal@3.11.2-6+deb12u6?distro=debian-12" }, { "@id": "pkg:deb/debian/libpython3.11-stdlib@3.11.2-6+deb12u6?distro=debian-12" } ] },
        { "@id": "pkg:oci/ml-engine", "subcomponents": [ { "@id": "pkg:deb/debian/python3.11-minimal@3.11.2-6+deb12u6?distro=debian-12" }, { "@id": "pkg:deb/debian/libpython3.11-minimal@3.11.2-6+deb12u6?distro=debian-12" }, { "@id": "pkg:deb/debian/libpython3.11-stdlib@3.11.2-6+deb12u6?distro=debian-12" } ] }
      ],
      "status": "not_affected",
      "justification": "component_not_present",
      "impact_statement": "The Python 3.11 interpreter and its standard library are removed from the final image (files and dpkg metadata). The application runs on Python 3.12 (genai-engine) / 3.13 (ml-engine) from /usr/local, which is unaffected by this CVE."
    },
