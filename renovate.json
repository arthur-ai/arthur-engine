{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "minimumReleaseAge": "3 days",
  "schedule": ["* 0-4 * * *"],
  "automergeSchedule": ["* 0-4 * * *"],
  "timezone": "America/New_York",
  "enabledManagers": ["npm", "uv"],
  "includePaths": [
    "genai-engine/ui/package.json",
    "genai-engine/ui/yarn.lock",
    "**/pyproject.toml",
    "**/uv.lock"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "autoApprove": true
    },
    {
      "matchPackageNames": ["python", "torch", "numpy"],
      "enabled": false
    }
  ]
}
