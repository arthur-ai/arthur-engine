{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "minimumReleaseAge": "3 days",
  "schedule": ["* 0-4 * * *"],
  "automergeSchedule": ["* 0-4 * * *"],
  "timezone": "America/New_York",
  "enabledManagers": ["npm", "pep621", "dockerfile", "docker-compose"],
  "includePaths": [
    "genai-engine/ui/package.json",
    "genai-engine/ui/yarn.lock",
    "**/pyproject.toml",
    "**/uv.lock",
    "**/Dockerfile",
    "**/dockerfile",
    "**/Dockerfile_*",
    "**/docker-compose*.yml",
    "**/docker-compose*.yaml"
  ],
  "osvVulnerabilityAlerts": true,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["* 0-4 * * 1"]
  },
  "dockerfile": {
    "managerFilePatterns": ["(^|/)[Dd]ockerfile$", "(^|/)Dockerfile_[a-zA-Z]+$"]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "autoApprove": true
    },
    {
      "matchManagers": ["pep621"],
      "matchPackageNames": ["python", "torch", "numpy"],
      "enabled": false
    },
    {
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchPackageNames": ["python"],
      "enabled": false
    },
    {
      "matchManagers": ["npm"],
      "reviewers": ["TheLukaszNs-Blazity", "xV3rt", "martin-arthur-ai"],
      "reviewersSampleSize": 1
    },
    {
      "matchManagers": ["pep621"],
      "reviewers": ["notthattal", "videetparekh", "mcgrawia"],
      "reviewersSampleSize": 1
    }
  ]
}
