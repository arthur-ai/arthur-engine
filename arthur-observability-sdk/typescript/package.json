{
  "name": "@arthur-ai/observability-sdk",
  "version": "1.0.4",
  "description": "Arthur Observability SDK — telemetry, prompt management, and framework instrumentation for Node.js",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./mastra": {
      "import": {
        "types": "./dist/mastra/index.d.mts",
        "default": "./dist/mastra/index.mjs"
      },
      "require": {
        "types": "./dist/mastra/index.d.ts",
        "default": "./dist/mastra/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "check": "npm run type-check && npm run lint && npm run format:check",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@arizeai/openinference-core": "^0.3.0",
    "@arizeai/openinference-semantic-conventions": "^0.11.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@opentelemetry/sdk-trace-node": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "axios": "^1.7.0"
  },
  "peerDependencies": {
    "@arizeai/openinference-instrumentation-anthropic": "*",
    "@arizeai/openinference-instrumentation-bedrock": "*",
    "@arizeai/openinference-instrumentation-bedrock-agent-runtime": "*",
    "@arizeai/openinference-instrumentation-beeai": "*",
    "@arizeai/openinference-instrumentation-claude-agent-sdk": "*",
    "@arizeai/openinference-instrumentation-langchain": "*",
    "@arizeai/openinference-instrumentation-mcp": "*",
    "@arizeai/openinference-instrumentation-openai": "*",
    "@mastra/core": "*"
  },
  "peerDependenciesMeta": {
    "@mastra/core": {
      "optional": true
    },
    "@arizeai/openinference-instrumentation-openai": {
      "optional": true
    },
    "@arizeai/openinference-instrumentation-anthropic": {
      "optional": true
    },
    "@arizeai/openinference-instrumentation-langchain": {
      "optional": true
    },
    "@arizeai/openinference-instrumentation-claude-agent-sdk": {
      "optional": true
    },
    "@arizeai/openinference-instrumentation-bedrock": {
      "optional": true
    },
    "@arizeai/openinference-instrumentation-bedrock-agent-runtime": {
      "optional": true
    },
    "@arizeai/openinference-instrumentation-beeai": {
      "optional": true
    },
    "@arizeai/openinference-instrumentation-mcp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "arthur",
    "observability",
    "opentelemetry",
    "llm",
    "ai",
    "monitoring"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/arthur-ai/arthur-engine.git",
    "directory": "arthur-observability-sdk/typescript"
  }
}
